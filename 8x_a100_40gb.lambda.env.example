# Recommended profile for one 8x NVIDIA A100 SXM4 node:
# - 8x A100 SXM4
# - 40 GB GPU memory each
# - 124 vCPUs, 1800 GiB RAM, 6 TiB SSD
#
# Copy to a real env file, edit paths/filesystem, then:
#   source ./8x_a100_40gb.lambda.env
#
# Default layout for the first 14B fit probe:
# - GPUs 0-5: DeepSpeed ZeRO-3 GRPO training ranks
# - GPUs 6-7: TRL vLLM server with tensor parallel size 2
#
# This profile is not equivalent to 2x H100. It trades lower per-GPU VRAM
# for more GPUs and sharded training.

export REPT_PROFILE=8x-a100-40gb-server-ds

# Absolute path to the copied PT snapshot inside model-run on the GPU machine.
export REPT_ROOT=/home/ubuntu/csci-544/model-run/ReasoningEconomicsPT

# Absolute path to the Python venv used for Lambda/GPU training.
export REPT_VENV=/home/ubuntu/.venvs/rept-8x-a100-40gb

# Absolute path to the copied Env snapshot inside model-run on the GPU machine.
export ENV_ROOT=/home/ubuntu/csci-544/model-run/ReasoningEconomicsEnv

# Lambda filesystem settings. Change this to your mounted filesystem name.
export REPT_FS_NAME=csci-544
export REPT_DATA_ROOT=/lambda/nfs/$REPT_FS_NAME/rept

# OpenEnv endpoint.
export ENV_BASE_URL=http://127.0.0.1:8010

# CUDA wheel index. Use cu128 on recent Lambda images/drivers. If bootstrap
# cannot find matching wheels, try cu126 or cu124.
export PYTORCH_WHEEL_INDEX=https://download.pytorch.org/whl/cu128
export REPT_VENV_SYSTEM_SITE_PACKAGES=0
export REPT_SKIP_TORCH_INSTALL=0
export REPT_PYTHON_BIN=auto
export REPT_RECREATE_VENV=0

# OpenEnv server bootstrap uses a clean Python 3.11 venv.
export ENV_PYTHON_BIN=python3.11
export ENV_VENV_SYSTEM_SITE_PACKAGES=0

# --- First 14B server-mode fit probe ---
export REPT_MODEL=Qwen/Qwen3-14B
export REPT_OUTPUT_DIR=$REPT_DATA_ROOT/runs/14b_a100x8_srvtp2_ds6_ctx5120_96cap_probe
export REPT_NUM_EPOCHS=1
export REPT_NUM_GENERATIONS=2
export REPT_BATCH_SIZE=2
export REPT_GRAD_ACCUM=1
export REPT_GRAD_ACCUM_OVERRIDE=1
export REPT_ALPHA=1.0
export REPT_LOG_EVERY=1
export REPT_N_PROMPTS=1
export REPT_MAX_EPISODE_TURNS=3
export REPT_MAX_STEPS=1

# 8x A100 split layout: 6 training GPUs + 2 vLLM GPUs.
export REPT_NUM_GPUS=8
export REPT_VLLM_MODE=server
export REPT_VLLM_TP=2
export REPT_VLLM_GPU_UTIL=0.80
export REPT_VLLM_MAX_MODEL_LEN=5120
export REPT_VLLM_PORT=8002
export REPT_VLLM_GROUP_PORT=51217
export REPT_VLLM_SERVER_HOST=127.0.0.1
export REPT_ACCELERATE_MAIN_PORT=29500

# DeepSpeed ZeRO-3 across the 6 training GPUs.
export REPT_SHARDING_BACKEND=deepspeed
export REPT_DEEPSPEED_CONFIG=$REPT_ROOT/configs/deepspeed/zero3_8x_a100_40gb.json
export REPT_GRADIENT_CHECKPOINTING=1
export REPT_NCCL_P2P_DISABLE=0

# 10-question episode mode with soft budget.
export REASON_BUDGET_NUM_QUESTIONS=10
export REASON_BUDGET_HARD_CAP_MODE=0
export REASON_BUDGET_SOFT_ALLOW_NEGATIVE_BUDGET=1
export REASON_BUDGET_SOFT_OVERSPEND_PENALTY=0.25
export REASON_BUDGET_BUDGET_RATIO=4.0
export REPT_DEFAULT_BUDGET_MODE=soft
export REPT_MAX_COMPLETION_LENGTH=96
export REPT_MAX_TOKENS_PER_STEP=96

export REPT_INSTALL_DEPS_ON_RUN=0

export REPT_SCOUT_OUTPUT=$REPT_DATA_ROOT/runs/openenv_seed_manifest_qwen3_14b_a100x8_1.json
export REPT_SCOUT_N_SEEDS=1

# --- After the fit probe passes, switch to the real 10-question run ---
# export REPT_OUTPUT_DIR=$REPT_DATA_ROOT/runs/14b_a100x8_srvtp2_ds6_ctx5120_96cap_10q
# export REPT_MAX_EPISODE_TURNS=12
# unset REPT_MAX_STEPS

# --- If ctx5120 fails during vLLM engine init, try the fallback geometry ---
# export REPT_OUTPUT_DIR=$REPT_DATA_ROOT/runs/14b_a100x8_srvtp2_ds6_ctx4608_64cap_probe
# export REPT_VLLM_MAX_MODEL_LEN=4608
# export REPT_MAX_COMPLETION_LENGTH=64
# export REPT_MAX_TOKENS_PER_STEP=64
# export REPT_MAX_EPISODE_TURNS=3
# export REPT_MAX_STEPS=1

# --- If 14B training logprob OOMs, reduce per-device batch pressure first ---
# export REPT_NUM_GENERATIONS=2
# export REPT_BATCH_SIZE=2
# export REPT_GRAD_ACCUM=2
# export REPT_GRAD_ACCUM_OVERRIDE=1

