# Recommended profile for one AWS p5.4xlarge instance:
# - 1x NVIDIA H100
# - 80 GB HBM3 GPU memory
#
# This profile is tuned for the current OpenEnv episode-mode GRPO path on a single H100.
# It keeps Qwen/Qwen3-14B as the bundle default; override to Qwen/Qwen3-1.7B for the first smoke.
#
# Copy to a real env file, edit values, then:
#   source ./p5_4xlarge_h100.lambda.env

export REPT_PROFILE=p5.4xlarge-single-h100

# Absolute path to the copied PT snapshot inside model-run on the GPU machine.
export REPT_ROOT=/home/ubuntu/csci-544/model-run/ReasoningEconomicsPT

# Absolute path to the Python venv used for Lambda/GPU training.
export REPT_VENV=/home/ubuntu/.venvs/rept-lambda

# Absolute path to the copied Env snapshot inside model-run on the GPU machine.
export ENV_ROOT=/home/ubuntu/csci-544/model-run/ReasoningEconomicsEnv

# Lambda filesystem settings.
export REPT_FS_NAME=<lambda-filesystem-name>
export REPT_DATA_ROOT=/lambda/nfs/$REPT_FS_NAME/rept

# OpenEnv endpoint.
export ENV_BASE_URL=http://127.0.0.1:8010

# Single-H100 bundle defaults.
export REPT_MODEL=Qwen/Qwen3-14B
export REPT_OUTPUT_DIR=$REPT_DATA_ROOT/runs/grpo_qwen3_14b_p5_4xlarge
export REPT_NUM_EPOCHS=1
export REPT_NUM_GENERATIONS=4
export REPT_BATCH_SIZE=4
export REPT_GRAD_ACCUM=1
export REPT_VLLM_MODE=colocate
export REPT_VLLM_TP=1
export REPT_VLLM_GPU_UTIL=0.25
export REPT_ALPHA=1.0
export REPT_LOG_EVERY=1
export REPT_N_PROMPTS=50

# Current Lambda profile: 10-question episode mode with soft budget.
export REASON_BUDGET_NUM_QUESTIONS=10
export REASON_BUDGET_HARD_CAP_MODE=0
export REASON_BUDGET_SOFT_ALLOW_NEGATIVE_BUDGET=1
export REASON_BUDGET_SOFT_OVERSPEND_PENALTY=0.25
export REASON_BUDGET_BUDGET_RATIO=4.0
export REPT_DEFAULT_BUDGET_MODE=soft
export REPT_MAX_COMPLETION_LENGTH=2048
export REPT_MAX_TOKENS_PER_STEP=$REPT_MAX_COMPLETION_LENGTH
# Raise only if full 10-question episodes still clip:
# export REPT_MAX_COMPLETION_LENGTH=3072
# export REPT_MAX_COMPLETION_LENGTH=4096

# Optional: if vLLM server mode or KV allocation needs tuning.
# export REPT_VLLM_MODE=auto
# export REPT_VLLM_MAX_MODEL_LEN=4096

# Optional dependency override if CUDA wheel resolution needs it.
# export REPT_REQUIREMENTS_FILE=$REPT_ROOT/requirements.lambda.txt
# export PYTORCH_WHEEL_INDEX=https://download.pytorch.org/whl/cu121

# GH200 / ARM64 note:
# On Lambda Stack GH200 images, prefer reusing the image's system torch in a venv
# created with --system-site-packages rather than reinstalling the pinned torch wheel.
# export REPT_VENV_SYSTEM_SITE_PACKAGES=1
# export REPT_SKIP_TORCH_INSTALL=1

export REPT_INSTALL_DEPS_ON_RUN=0

export REPT_SCOUT_OUTPUT=$REPT_DATA_ROOT/runs/openenv_seed_manifest_qwen3_14b_50.json
export REPT_SCOUT_N_SEEDS=50
