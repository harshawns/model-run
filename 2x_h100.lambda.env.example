# Recommended profile for one Lambda / cloud instance with 2x NVIDIA H100 GPUs.
#
# Layout used by the current launcher:
# - GPU 0: GRPO training process
# - GPU 1: TRL vLLM server
#
# This is not tensor-parallel training across both GPUs. It is a split
# train/generation layout that reduces colocate memory pressure.
#
# Copy to a real env file, edit values, then:
#   source ./2x_h100.lambda.env

export REPT_PROFILE=2x-h100-server

# Absolute path to the copied PT snapshot inside model-run on the GPU machine.
export REPT_ROOT=/home/ubuntu/csci-544/model-run/ReasoningEconomicsPT

# Absolute path to the Python venv used for Lambda/GPU training.
export REPT_VENV=/home/ubuntu/.venvs/rept-2x-h100

# Absolute path to the copied Env snapshot inside model-run on the GPU machine.
export ENV_ROOT=/home/ubuntu/csci-544/model-run/ReasoningEconomicsEnv

# Lambda filesystem settings. Change this if your Lambda filesystem has a
# different name.
export REPT_FS_NAME=csci-544
export REPT_DATA_ROOT=/lambda/nfs/$REPT_FS_NAME/rept

# OpenEnv endpoint.
export ENV_BASE_URL=http://127.0.0.1:8010

# CUDA wheel index. Use cu128 on recent Lambda images/drivers. If bootstrap
# cannot find a matching wheel, try cu126 or cu124.
export PYTORCH_WHEEL_INDEX=https://download.pytorch.org/whl/cu128
export REPT_VENV_SYSTEM_SITE_PACKAGES=0
export REPT_SKIP_TORCH_INSTALL=0
export REPT_PYTHON_BIN=auto
export REPT_RECREATE_VENV=0

# OpenEnv server bootstrap uses a clean Python 3.11 venv.
export ENV_PYTHON_BIN=python3.11
export ENV_VENV_SYSTEM_SITE_PACKAGES=0

# First recommended 2x H100 smoke. Move to Qwen/Qwen3-8B or 14B after this works.
export REPT_MODEL=Qwen/Qwen3-1.7B
export REPT_OUTPUT_DIR=$REPT_DATA_ROOT/runs/grpo_qwen3_1p7b_2x_h100_smoke
export REPT_NUM_EPOCHS=1
export REPT_NUM_GENERATIONS=2
export REPT_BATCH_SIZE=2
export REPT_GRAD_ACCUM=1
export REPT_GRAD_ACCUM_OVERRIDE=1
export REPT_ALPHA=1.0
export REPT_LOG_EVERY=1
export REPT_N_PROMPTS=1
export REPT_MAX_EPISODE_TURNS=12

# 2x H100 split layout: vLLM server on one GPU, trainer on the other.
export REPT_NUM_GPUS=auto
export REPT_VLLM_MODE=server
export REPT_VLLM_TP=1
# Conservative for the Qwen3-1.7B smoke so failed/restarted servers do not
# over-reserve the vLLM GPU. Raise for larger models after this passes.
export REPT_VLLM_GPU_UTIL=0.35
export REPT_VLLM_MAX_MODEL_LEN=4096
export REPT_VLLM_PORT=8001
export REPT_VLLM_GROUP_PORT=51216
export REPT_VLLM_SERVER_HOST=127.0.0.1
export REPT_ACCELERATE_MAIN_PORT=29500

# 10-question episode mode with soft budget and no separate tighter per-step cap.
export REASON_BUDGET_NUM_QUESTIONS=10
export REASON_BUDGET_HARD_CAP_MODE=0
export REASON_BUDGET_SOFT_ALLOW_NEGATIVE_BUDGET=1
export REASON_BUDGET_SOFT_OVERSPEND_PENALTY=0.25
export REASON_BUDGET_BUDGET_RATIO=4.0
export REPT_DEFAULT_BUDGET_MODE=soft
export REPT_MAX_COMPLETION_LENGTH=1024
export REPT_MAX_TOKENS_PER_STEP=$REPT_MAX_COMPLETION_LENGTH

# Raise only if full 10-question episodes clip or terminate early.
# export REPT_MAX_COMPLETION_LENGTH=2048
# export REPT_MAX_COMPLETION_LENGTH=2560
# export REPT_MAX_COMPLETION_LENGTH=3072

export REPT_INSTALL_DEPS_ON_RUN=0

export REPT_SCOUT_OUTPUT=$REPT_DATA_ROOT/runs/openenv_seed_manifest_qwen3_1p7b_2x_h100_1.json
export REPT_SCOUT_N_SEEDS=1
